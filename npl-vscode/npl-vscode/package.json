{
  "name": "npl",
  "displayName": "NPL - Nathan Programming Language",
  "description": "Syntax highlighting for NPL",
  "version": "0.0.1",
  "engines": { "vscode": "^1.60.0" },
  "contributes": {
    "languages": [{
      "id": "npl",
      "extensions": [".npl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "npl",
      "scopeName": "source.npl",
      "path": "./syntaxes/npl.tmLanguage.json"
    }]
  }
}
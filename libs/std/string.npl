fn len(s) -> << string_length(s)
fn up(s) -> << string_upper(s)
fn low(s) -> << string_lower(s)
fn trim(s) -> << string_trim(s)
fn has(s, sub) -> << string_contains(s, sub)
fn starts(s, sub) -> << string_starts_with(s, sub)
fn ends(s, sub) -> << string_ends_with(s, sub)
fn replace(s, from, to) -> << string_replace(s, from, to)
fn split(s, delim) -> << string_split(s, delim)
fn join(arr, delim) -> << string_join(arr, delim)

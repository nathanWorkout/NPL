fn abs(n) -> {
    if n < 0 -> << n * -1
    else -> << n
}

fn max(a, b) -> {
    if a > b -> << a
    else -> << b
}

fn min(a, b) -> {
    if a < b -> << a
    else -> << b
}

fn clamp(val, min, max) -> {
    if val < min -> <<  min
    if val > max -> << max
    else -> << val
}

fn pow(base, exp) -> {
    result = 1
    repeat exp -> result = result * base
    << result
}

fn floor(n) -> {
    remainder = n % 1
    n = n - remainder
    << n
}

>> floor(3.7)
>> floor(-4.5)



# Commentaire
x = 10
y = 3.14
nom = "Nathan"
actif = true

>> x
>> y
>> nom
>> actif

if x > 5 -> >> "x est grand"
if x == 10 -> >> "x vaut 10"
if actif -> >> "actif est true"

if x > 5 -> {
    >> "dans le bloc"
    >> x
}

if x > 20 -> >> "tres grand"
elif x > 5 -> >> "moyen"
else -> >> "petit"

repeat 3 -> >> "rep inline"

repeat 3 -> {
    >> "rep bloc"
    >> x
}

i = 0
while i < 3 -> {
    >> i
    i = i + 1
}

for j = 0; j < 5; j++ -> >> j

for k = 0; k < 3; k++ -> {
    >> "k ="
    >> k
}

fn saluer(nom) -> >> nom

saluer("Nathan")

arr = [1, 2, 3]
>> arr[0]
arr[1] = 99
>> arr

fn doubler(x) -> {
    << x * 2
}

result = doubler(5)
>> result
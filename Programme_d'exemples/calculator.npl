# This is my programming langage :)
# Simple programme : calculator

fn add(a, b) -> << a + b
fn sub(a, b) -> << a - b
fn mult(a, b) -> << a * b

fn div(a, b) -> {
    if b == 0 -> >> "Error : divide by 0"
    else -> << a / b
}

a = ?> "Premier nombre : "
b = ?> "Deuxieme nombre : "

>> add(a, b)
>> sub(a, b)
>> mult(a, b)
>> div(a, b)

>> string_length("hello")
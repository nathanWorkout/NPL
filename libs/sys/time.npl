fn time() -> << time_map()

fn get_date(m) -> << m   

fn day(m)   -> << m["day"]
fn month(m) -> << m["month"]  
fn year(m)  -> << m["year"]
fn hour(m)  -> << m["hours"]
fn min(m)   -> << m["minutes"]
fn sec(m)   -> << m["seconds"]

fn format_date(m) -> << m["day"] + "/" + m["month"] + "/" + m["year"]
fn format_time(m) -> << m["hours"] + ":" + m["minutes"] + ":" + m["seconds"]